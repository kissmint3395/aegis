{
    "name": "kissmint3395/aegis",
    "description": "A PHP 8.2+ resilience library combining Retry, Circuit Breaker, Timeout, and more into a composable pipeline. Inspired by Resilience4j and .NET Polly.",
    "type": "library",
    "license": "MIT",
    "keywords": ["resilience", "retry", "circuit-breaker", "timeout", "fault-tolerance"],
    "authors": [
        {
            "name": "kissmint3395",
            "homepage": "https://github.com/kissmint3395"
        }
    ],
    "support": {
        "issues": "https://github.com/kissmint3395/aegis/issues",
        "source": "https://github.com/kissmint3395/aegis"
    },
    "require": {
        "php": "^8.2",
        "psr/event-dispatcher": "^1.0",
        "psr/simple-cache": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "phpstan/phpstan-strict-rules": "^1.5",
        "phpstan/extension-installer": "^1.3"
    },
    "autoload": {
        "psr-4": {
            "Aegis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aegis\\Tests\\": "tests/",
            "Aegis\\PHPStan\\": "phpstan/"
        }
    },
    "extra": {
        "phpstan": {
            "includes": ["phpstan/extension.neon"]
        }
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    }
}
